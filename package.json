    "drizzle-orm": "^0.29.3",
    "elysia": "^1.0.0",
    "fuse.js": "^7.1.0",
    "ip-range-check": "^0.2.0",
    "libsql": "^0.3.0",
    "lucide-react": "^0.330.0",
    "next-themes": "^0.3.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^2.2.1",
