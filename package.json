{
  "name": "ripfetch",
  "description": "Furry-friendly game download aggregator - Fetching game downloads for you! OwO",
  "module": "src/index.ts",
  "type": "module",
  "author": {
    "name": "michei69",
    "email": "hey@michei.dev",
    "url": "https://github.com/michei69"
  },
  "scripts": {
    "dev": "cross-env DEV=true VITE_DEV=true concurrently -k \"bun ./src/server/index.ts\" \"vite\"",
    "dev:client": "vite",
    "dev:server": "bun ./src/server/index.ts",
    "build": "cross-env VITE_DEV=false vite build",
    "serve": "bun ./src/server/index-prod.ts",
    "start": "bun run build && bun run serve"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.0.0",
    "@elysiajs/swagger": "^1.0.0",
    "@libsql/client": "^0.6.0",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tooltip": "^1.0.7",
    "autoprefixer": "^10.4.17",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.0",
